{
  "name": "poc-playwright-claude",
  "version": "0.1.0",
  "description": "POC: Claude Code + Playwright CLI para testes automatizados, sessoes autenticadas e scraping",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "auth": "playwright test --project=setup",
    "scrape": "tsx scripts/scrape.ts",
    "explore": "tsx scripts/explore.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
