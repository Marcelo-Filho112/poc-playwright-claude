# Copie para .env e ajuste os valores.  cp .env.example .env

# URL base da app-alvo. Default do projeto: http://localhost:3000
BASE_URL=http://localhost:3000

# Rodando via container Docker e a app esta no HOST? O "localhost" do container
# nao e o seu. Use o gateway do host:
#   BASE_URL=http://host.docker.internal:3000

# Credenciais usadas pelo setup de autenticacao (auth/auth.setup.ts).
TEST_USER=seu-usuario@exemplo.com
TEST_PASS=sua-senha
